{
    "name": "@xsqu1znt/kbot-core",
    "version": "0.1.0",
    "description": "The core systems used for my card bots.",
    "license": "MIT",
    "author": "xsqu1znt",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsup",
        "check": "tsc --noEmit",
        "format": "prettier --write \"./**/*.{ts,json}\"",
        "push": "pnpm build && git add . && git commit -m \"chore: build - $(date +'%Y-%m-%d %H:%M:%S')\" && git push"
    },
    "peerDependencies": {
        "@napi-rs/canvas": "^0.1.97",
        "axios": "^1.13.6",
        "discord.js": "^14.25.1",
        "mongoose": "^8.23.0",
        "qznt": "^1.0.36",
        "sharp": "^0.34.5",
        "vimcord": "^1.0.49"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@napi-rs/canvas": "^0.1.97",
        "@types/node": "^22.19.17",
        "axios": "^1.15.0",
        "discord.js": "^14.26.2",
        "mongoose": "^8.23.0",
        "prettier": "^3.8.2",
        "qznt": "^1.0.36",
        "sharp": "^0.34.5",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vimcord": "^1.0.50"
    }
}
